    "Track 1RM estimates and view exercise history charts to measure your progress.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track 1RM estimates and view exercise history charts to measure your progress."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1RM推定値を追跡し、エクササイズ履歴チャートで進捗を確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "1RM 추정치를 추적하고 운동 히스토리 차트를 확인하여 진행 상황을 측정하세요."
          }
        }
      }
    },
    "Track daily habits and keep auto achievements moving with your routine.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日々の習慣を記録し、ルーティンに合わせて自動達成の流れを続けましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일상 루틴과 함께 일일 습관을 추적하고 자동 업적 흐름을 이어가세요."
          }
        }
      }
    },
    "Track distance, pace, and heart rate in real time during runs and walks.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track distance, pace, and heart rate in real time during runs and walks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランニングやウォーキング中に距離、ペース、心拍数をリアルタイムで追跡しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "달리기와 걷기 중 거리, 페이스, 심박수를 실시간으로 추적하세요."
          }
        }
      }
    },
    "Track Expenses": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
