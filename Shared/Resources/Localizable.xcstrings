    "Health alerts are sent at most once per day, duplicates are suppressed for one hour, and informational alerts use a daily budget.": {},
    "Health alerts are sent at most once per day. Workout records notify every time.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "健康アラートは1日最大1回送信されます。ワークアウト記録は毎回通知されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "건강 알림은 하루 최대 1회 전송됩니다. 운동 기록은 매번 알림합니다."
          }
        }
      }
    },
