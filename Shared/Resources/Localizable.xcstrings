    "Heading to bed around your usual time can improve sleep quality, recovery, and workout consistency.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつもの時間に就寝すると、睡眠の質や回復、運動習慣の安定につながります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "평소 취침 시간에 맞춰 잠자리에 들면 수면의 질과 회복, 운동 루틴 유지에 도움이 돼요."
          }
        }
      }
    },
