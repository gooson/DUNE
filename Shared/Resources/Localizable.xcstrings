    "%@ and %lld muscle groups total show very high fatigue. Rest for 1–2 days, then ease back in with light exercise.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@を含む合計%lld筋群で非常に高い疲労が見られます。1〜2日休息してから、軽い運動で復帰しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@을 포함한 총 %lld개 근육군의 피로도가 매우 높습니다. 1-2일 휴식 후 가벼운 운동으로 복귀하세요."
          }
        }
      }
    },
