    "DUNE skips this reminder when recent Apple Watch heart-rate data suggests you're already wearing your watch." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最近のApple Watch心拍データからすでに着用中と判断した場合、DUNEはこの通知を送信しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최근 Apple Watch 심박 데이터로 이미 시계를 착용 중인 것으로 보이면 DUNE이 이 알림을 건너뜁니다."
          }
        }
      }
    },
    "DUNE skips this reminder when recent heart-rate data suggests you're already wearing your watch." : {
      "extractionState" : "manual",
