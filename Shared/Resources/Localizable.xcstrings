    "Final score = HRV(30%) + RHR(20%) + Sleep(25%) + Recovery(15%) + Trend(10%)." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最終スコア = HRV(30%) + RHR(20%) + 睡眠(25%) + 回復(15%) + トレンド(10%)。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최종 점수 = HRV(30%) + RHR(20%) + 수면(25%) + 회복(15%) + 추세(10%)."
          }
        }
      }
    },
    "Final score = weighted average of Sleep(40%), Condition(35%), and Body(25%)." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最終スコア = 睡眠(40%)、コンディション(35%)、ボディ(25%)の加重平均です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "최종 점수 = 수면(40%), 컨디션(35%), 신체(25%)의 가중 평균입니다."
          }
        }
      }
