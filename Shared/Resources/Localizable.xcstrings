          }
        }
      }
    },
    "See sleep, body, and active indicators together in one score-driven view.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "睡眠、身体記録、アクティブ指標をひとつのスコア中心ビューでまとめて確認できます。"
          }
