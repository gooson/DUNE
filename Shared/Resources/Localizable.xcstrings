          }
        }
      }
    },
    "Track minutes spent": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "所要時間を記録"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소요 시간 추적"
          }
        }
      }
    },
    "Track number of times": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "回数を記録"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "횟수 추적"
          }
        }
      }
    },
    "Track stair climber workouts and count flights climbed alongside steps and heart rate.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステアクライマーのワークアウトを記録し、歩数や心拍数と一緒に上った階数をカウントします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계단 오르기 운동을 기록하고 걸음 수, 심박수와 함께 오른 층수를 추적합니다."
          }
        }
      }
    },
    "Track workouts on Apple Watch and sync completed sessions back to iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track workouts on Apple Watch and sync completed sessions back to iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watchでワークアウトを追跡し、完了したセッションをiPhoneに同期しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Watch에서 운동을 추적하고 완료된 세션을 iPhone으로 동기화하세요."
          }
        }
      }
    },
    "Track workouts, check your condition, and see your progress — all built around your body's data.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track workouts, check your condition, and see your progress — all built around your body's data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークアウトを記録し、コンディションを確認し、進捗を追跡しましょう — すべてあなたの体のデータに基づいています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동을 기록하고, 컨디션을 확인하고, 진행 상황을 확인하세요 — 모두 당신의 신체 데이터를 기반으로 합니다."
          }
        }
      }
    },
    "Track your RPE trend over time with a moving average chart, and receive coaching alerts when overtraining patterns emerge.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "移動平均チャートでRPEトレンドを追跡し、オーバートレーニングパターンが検出されるとコーチングアラートを受け取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이동 평균 차트로 RPE 트렌드를 추적하고, 오버트레이닝 패턴이 감지되면 코칭 알림을 받으세요."
          }
        }
      }
    },
    "Track your workouts and wear Apple Watch to see your training readiness breakdown.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークアウトを記録しApple Watchを着けてトレーニング準備度の内訳を確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동을 기록하고 Apple Watch를 착용하여 트레이닝 준비도 상세를 확인하세요."
          }
        }
      }
    },
    "Track your workouts and wear Apple Watch to see your training readiness score.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークアウトを記録しApple Watchを着けてトレーニング準備度スコアを確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동을 기록하고 Apple Watch를 착용하여 트레이닝 준비도 점수를 확인하세요."
          }
        }
      }
    },
    "Tracks how consistently you work out. Check your consistency through workout streaks and monthly progress.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どれだけ継続的に運動しているか追跡します。ワークアウトの連続記録と月間進捗で一貫性を確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "얼마나 꾸준히 운동하는지 추적해요. 운동 연속 기록과 월간 진행으로 일관성을 확인하세요."
          }
        }
      }
    },
    "Tracks your personal bests by analyzing both strength and cardio records. View your progress on one screen and use it to adjust your training direction.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "筋力と有酸素の記録を分析して自己ベストを追跡します。一画面で進捗を確認し、トレーニングの方向性を調整しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "근력과 유산소 기록을 분석하여 개인 최고 기록을 추적해요. 한 화면에서 진행 상황을 확인하고 훈련 방향을 조정하세요."
          }
        }
      }
    },
    "Train for a few days to see your injury risk assessment.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "数日間トレーニングすると怪我リスク評価が表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "며칠간 훈련하면 부상 위험 평가를 볼 수 있어요."
          }
        }
      }
    },
    "Trained %lld of %lld days": {
      "localizations": {
