            "state": "translated",
            "value": "먼저 운동 이름을 전사문에 넣어 주세요."
          }
        }
      }
    },
    "Add at least one exercise": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクササイズを1つ以上追加してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동을 하나 이상 추가해주세요"
          }
        }
      }
    },
    "Add DUNE widgets to your Home Screen and glance at your key scores without opening the app.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DUNEウィジェットをホーム画面に追加して、アプリを開かずに主要スコアをすぐ確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "DUNE 위젯을 홈 화면에 추가하고 앱을 열지 않아도 핵심 점수를 바로 확인해보세요."
          }
        }
      }
    },
    "Add duration for this workout draft.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このワークアウト下書きには時間を追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 운동 초안에는 시간을 추가해 주세요."
          }
        }
      }
    },
    "Add duration or distance for this cardio draft.": {
      "localizations": {
        "ja": {
