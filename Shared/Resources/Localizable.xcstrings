    "Final score = HRV(30%) + RHR(20%) + Sleep(25%) + Recovery(15%) + Trend(10%).": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最終スコア = HRV(30%) + RHR(20%) + 睡眠(25%) + 回復(15%) + トレンド(10%)。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최종 점수 = HRV(30%) + RHR(20%) + 수면(25%) + 회복(15%) + 추세(10%)."
          }
        }
      }
    },
    "Final score = weighted average of Sleep(35%), Condition(30%), Body(20%), and Posture(15%).": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最終スコア = 睡眠(35%)、コンディション(30%)、ボディ(20%)、姿勢(15%)の加重平均です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최종 점수 = 수면(35%), 컨디션(30%), 신체(20%), 자세(15%)의 가중 평균입니다."
