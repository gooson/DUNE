        }
      }
    },
    "Keep it light today. Low-intensity activities like stretching or yoga can help with recovery.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日は軽めにしましょう。ストレッチやヨガなどの低強度アクティビティが回復に役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘은 가볍게 하세요. 스트레칭이나 요가 같은 저강도 활동이 회복에 도움됩니다."
          }
        }
      }
    },
