    "Set a nightly reminder to wind down and protect your sleep schedule.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set a nightly reminder to wind down and protect your sleep schedule."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "毎晩のリマインダーを設定して、睡眠スケジュールを守りましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "매일 밤 리마인더를 설정하여 수면 스케줄을 보호하세요."
          }
        }
      }
    },
    "Set an ambitious goal today. It's the perfect time to chase a PR or try a new exercise.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日は高い目標を設定しましょう。PRに挑戦したり、新しいエクササイズを試すのに最適な時です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘은 높은 목표를 세워보세요. PR에 도전하거나 새로운 운동을 시도하기 완벽한 시기입니다."
          }
        }
      }
    },
    "Set default values and choose exercises that should stay near the top of Quick Start.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "運動ごとのデフォルト値を設定し、Quick Startの上位に置いておきたい運動を選びます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "운동별 기본값을 설정하고 Quick Start 상단에 유지할 운동을 고르세요."
          }
        }
      }
    },
    "Set default weight for each exercise. Last used weight is remembered automatically.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各エクササイズのデフォルト重量を設定してください。最後に使用した重量は自動的に記憶されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 운동의 기본 무게를 설정하세요. 마지막 사용 무게는 자동으로 기억돼요."
          }
        }
      }
    },
